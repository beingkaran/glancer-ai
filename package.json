{
  "name": "glancer-ai",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.mjs && node scripts/generate-events-ics.mjs && vite build && node scripts/prerender-blogs.mjs && node scripts/generate-topic-hubs.mjs && node scripts/prerender-static-pages.mjs",
    "build:topics": "node scripts/generate-topic-hubs.mjs",
    "roundup": "node scripts/generate-weekly-roundup.mjs",
    "build:vite": "vite build",
    "build:infographic": "python3 scripts/generate-glossary-infographic.py",
    "lint": "oxlint",
    "preview": "vite preview",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:open": "npm run android:sync && cap open android",
    "android:run": "npm run android:sync && cap run android"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@supabase/supabase-js": "^2.108.2",
    "@tiptap/extension-character-count": "^3.27.1",
    "@tiptap/extension-image": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/extension-underline": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "chart.js": "^4.5.1",
    "docx": "^9.7.1",
    "dompurify": "^3.4.11",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.21.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.7",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "vite": "^8.1.0"
  }
