{
  "appId": "com.glancerai.app",
  "appName": "Glancer AI",
  "webDir": "dist",
  "backgroundColor": "#F6F6F6",
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#F6F6F6",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#F6F6F6",
      "overlaysWebView": false
    }
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#F6F6F6"
  },
  "android": {
    "backgroundColor": "#F6F6F6"
  }
}
