{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "glancer-ai",
  "compatibility_date": "2026-06-26",
  // Static-asset-only Worker: serve the Vite build output, and fall back to
  // index.html for client-side routes (React Router SPA behaviour).
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
