# ─── Live AI for the Custom AI Tools ───────────────────────────────────────
# Set ONE of these (each has a free tier). Copy this file to `.env` for local
# dev, and add the same variable in your host's dashboard for production.
#
# 1) Google Gemini  — recommended, best free tier, no credit card
#    Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 2) Groq — free, extremely fast (Llama 3.3). Get a key: https://console.groq.com/keys
# GROQ_API_KEY=

# 3) OpenRouter — free `:free` models. Get a key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=

# Optional overrides
# LLM_PROVIDER=gemini        # force a provider: gemini | groq | openrouter
# LLM_MODEL=gemini-2.0-flash # override the model id

# ─── Auth + blog database (Supabase) ───────────────────────────────────────
# These two are PUBLIC (safe to ship to the browser). Real access control is
# enforced by Row Level Security in the database — see supabase/schema.sql.
# Get them from: Supabase Dashboard → Project Settings → API.
#   • VITE_SUPABASE_URL      = the "Project URL"
#   • VITE_SUPABASE_ANON_KEY = the "anon public" key
# The VITE_ prefix is required so Vite exposes them to the React app.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ─── CAPTCHA on sign-up / sign-in (Cloudflare Turnstile — optional) ─────────
# Leave blank to disable the CAPTCHA entirely. To enable:
#   1. Cloudflare dashboard → Turnstile → Add widget (free) → copy the SITE key
#      here, and the SECRET key into Supabase → Authentication → Settings →
#      "Enable Captcha protection" (provider: Turnstile).
#   2. Add your domain (and localhost for testing) to the widget's hostnames.
VITE_TURNSTILE_SITE_KEY=
